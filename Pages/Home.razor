@page "/"
@using Microsoft.Extensions.Localization
@using AboutMe.Services
@inject IStringLocalizer<Home> Localizer
@inject ThemeService ThemeService
@implements IDisposable

<style>
    .hover-card {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }
    .hover-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--mud-elevation-6) !important;
    }
</style>

<MudGrid Justify="Justify.Center">
    <!-- Hero / Apresentação -->
    <MudItem xs="12">
        <MudPaper Class="pa-6 animate-in" Elevation="3" Style="border-radius: 20px; overflow: hidden; position: relative; background: var(--mud-palette-background-grey);">
            <div style="position: absolute; top: 0; left: 0; width: 100%; height: 6px; background: linear-gradient(90deg, var(--mud-palette-primary) 0%, var(--mud-palette-secondary) 100%);"></div>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4" Class="flex-column flex-sm-row py-4">
                <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Style="width: 100px; height: 100px; font-size: 2.5rem; font-weight: 800; background: linear-gradient(135deg, var(--mud-palette-primary) 0%, var(--mud-palette-secondary) 100%); box-shadow: 0 4px 20px rgba(0,0,0,0.15);">
                    IS
                </MudAvatar>
                <MudStack Spacing="1" Class="align-center align-sm-start text-center text-sm-left flex-grow-1">
                    <MudText Typo="Typo.h3" Style="font-weight: 800; letter-spacing: -0.5px;" Class="name-title">
                        @Localizer["Name"]
                    </MudText>
                    <MudText Typo="Typo.h5" Color="Color.Primary" Style="font-weight: 600;">
                        @Localizer["CurrentRole"]
                    </MudText>
                    <MudStack Row="true" Spacing="2" Class="mt-3 flex-wrap justify-center justify-sm-start">
                        <MudButton StartIcon="@Icons.Material.Filled.Email" Href='@($"{Localizer["MailtoPrefix"]}{Localizer["EmailAddress"]}")' Variant="Variant.Filled" Color="Color.Primary" Style="text-transform: none; border-radius: 8px; font-weight: 500;">
                            @Localizer["EmailAddress"]
                        </MudButton>
                        <MudButton StartIcon="@Icons.Custom.Brands.LinkedIn" Href='@Localizer["LinkedInUrl"]' Target="_blank" Variant="Variant.Outlined" Color="Color.Secondary" Style="text-transform: none; border-radius: 8px; font-weight: 500;">
                            @Localizer["LinkedIn"]
                        </MudButton>
                        <MudButton StartIcon="@Icons.Custom.Brands.GitHub" Href='@Localizer["GitHubUrl"]' Target="_blank" Variant="Variant.Outlined" Color="Color.Dark" Style="text-transform: none; border-radius: 8px; font-weight: 500;">
                            @Localizer["GitHub"]
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>

    <!-- Resumo -->
    <MudItem xs="12">
        <div class="animate-in" style="animation-delay: 0.1s;">
            <MudPaper Class="pa-6" Elevation="3" Style="border-left: 6px solid var(--mud-palette-primary); border-radius: 12px;">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Primary" Size="Size.Medium" />
                    <MudText Typo="Typo.h5" Style="font-weight: 700;">@Localizer["ResumeTitle"]</MudText>
                </MudStack>
                <MudText Typo="Typo.body1" Style="line-height: 1.8; text-align: justify;">
                    @Localizer["ResumeText"]
                </MudText>
            </MudPaper>
        </div>
    </MudItem>

    <!-- Habilidades -->
    <MudItem xs="12">
        <div class="animate-in" style="animation-delay: 0.2s;">
            <MudText Typo="Typo.h5" Style="font-weight: 700;" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Code" Color="Color.Primary" Class="mr-2" />
                @Localizer["SkillsTitle"]
            </MudText>
            <MudGrid Spacing="3">
                <!-- Linguagens -->
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="3" Style="border-radius: 12px; height: 100%;" Class="pa-5 hover-card">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
                            <MudIcon Icon="@Icons.Material.Filled.Language" Color="Color.Primary" Size="Size.Medium" />
                            <MudText Typo="Typo.h6" Style="font-weight: 700;">@Localizer["SkillsLanguages"]</MudText>
                        </MudStack>
                        <MudStack Spacing="3">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                <i class="devicon-csharp-plain colored" style="font-size: 1.6rem; width: 24px; text-align: center;"></i>
                                <MudText Style="font-weight: 500;">@Localizer["SkillCSharp"]</MudText>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                <i class="devicon-javascript-plain colored" style="font-size: 1.6rem; width: 24px; text-align: center;"></i>
                                <MudText Style="font-weight: 500;">@Localizer["SkillJavascript"]</MudText>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                <i class="devicon-azuresqldatabase-plain colored" style="font-size: 1.6rem; width: 24px; text-align: center;"></i>
                                <MudText Style="font-weight: 500;">@Localizer["SkillSQL"]</MudText>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                </MudItem>
                <!-- Frameworks & Ferramentas -->
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="3" Style="border-radius: 12px; height: 100%;" Class="pa-5 hover-card">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
                            <MudIcon Icon="@Icons.Material.Filled.Build" Color="Color.Primary" Size="Size.Medium" />
                            <MudText Typo="Typo.h6" Style="font-weight: 700;">@Localizer["SkillsFrameworks"]</MudText>
                        </MudStack>
                        <MudStack Spacing="3">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                <i class="devicon-dotnetcore-plain colored" style="font-size: 1.6rem; width: 24px; text-align: center;"></i>
                                <MudText Style="font-weight: 500;">@Localizer["SkillDotNet"]</MudText>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                <i class="devicon-dotnetcore-plain colored" style="font-size: 1.6rem; width: 24px; text-align: center;"></i>
                                <MudText Style="font-weight: 500;">@Localizer["SkillAspNetCore"]</MudText>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                <i class="devicon-blazor-original colored" style="font-size: 1.6rem; width: 24px; text-align: center;"></i>
                                <MudText Style="font-weight: 500;">@Localizer["SkillBlazor"]</MudText>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                <i class="devicon-dotnetcore-plain colored" style="font-size: 1.6rem; width: 24px; text-align: center;"></i>
                                <MudText Style="font-weight: 500;">@Localizer["SkillRazorMvc"]</MudText>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                <i class="devicon-dotnetcore-plain colored" style="font-size: 1.6rem; width: 24px; text-align: center;"></i>
                                <MudText Style="font-weight: 500;">@Localizer["SkillEFCore"]</MudText>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                <i class="devicon-k6-plain colored" style="font-size: 1.6rem; width: 24px; text-align: center;"></i>
                                <MudText Style="font-weight: 500;">@Localizer["SkillK6"]</MudText>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                <MudIcon Icon="@Icons.Material.Filled.Insights" Color="Color.Primary" Size="Size.Medium" Style="width: 24px; text-align: center;" />
                                <MudText Style="font-weight: 500;">@Localizer["SkillDynatrace"]</MudText>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                <i class="devicon-sonarqube-plain colored" style="font-size: 1.6rem; width: 24px; text-align: center;"></i>
                                <MudText Style="font-weight: 500;">@Localizer["SkillSonarQube"]</MudText>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                <i class="devicon-github-original" style="font-size: 1.6rem; width: 24px; text-align: center;"></i>
                                <MudText Style="font-weight: 500;">@Localizer["SkillGithubCopilot"]</MudText>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                </MudItem>
                <!-- Cloud & Infra -->
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="3" Style="border-radius: 12px; height: 100%;" Class="pa-5 hover-card">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
                            <MudIcon Icon="@Icons.Material.Filled.Cloud" Color="Color.Primary" Size="Size.Medium" />
                            <MudText Typo="Typo.h6" Style="font-weight: 700;">@Localizer["SkillsCloud"]</MudText>
                        </MudStack>
                        <MudStack Spacing="3">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                <i class="devicon-azure-plain colored" style="font-size: 1.6rem; width: 24px; text-align: center;"></i>
                                <MudText Style="font-weight: 500;">@Localizer["SkillAzure"]</MudText>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                <i class="devicon-docker-plain colored" style="font-size: 1.6rem; width: 24px; text-align: center;"></i>
                                <MudText Style="font-weight: 500;">@Localizer["SkillDocker"]</MudText>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                <MudIcon Icon="@Icons.Material.Filled.SyncAlt" Color="Color.Primary" Size="Size.Medium" Style="width: 24px; text-align: center;" />
                                <MudText Style="font-weight: 500;">@Localizer["SkillCICD"]</MudText>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                <i class="devicon-dotnetcore-plain colored" style="font-size: 1.6rem; width: 24px; text-align: center;"></i>
                                <MudText Style="font-weight: 500;">@Localizer["SkillNetAspire"]</MudText>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                <i class="devicon-azuredevops-plain colored" style="font-size: 1.6rem; width: 24px; text-align: center;"></i>
                                <MudText Style="font-weight: 500;">@Localizer["SkillAzureDevOps"]</MudText>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                </MudItem>
                <!-- Bancos de Dados -->
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="3" Style="border-radius: 12px; height: 100%;" Class="pa-5 hover-card">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
                            <MudIcon Icon="@Icons.Material.Filled.Storage" Color="Color.Primary" Size="Size.Medium" />
                            <MudText Typo="Typo.h6" Style="font-weight: 700;">@Localizer["SkillsDatabases"]</MudText>
                        </MudStack>
                        <MudStack Spacing="3">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                <i class="devicon-microsoftsqlserver-plain colored" style="font-size: 1.6rem; width: 24px; text-align: center;"></i>
                                <MudText Style="font-weight: 500;">@Localizer["SkillSQLServer"]</MudText>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                <i class="devicon-postgresql-plain colored" style="font-size: 1.6rem; width: 24px; text-align: center;"></i>
                                <MudText Style="font-weight: 500;">@Localizer["SkillPostgreSql"]</MudText>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                <MudIcon Icon="@Icons.Material.Filled.Storage" Color="Color.Primary" Size="Size.Medium" Style="width: 24px; text-align: center;" />
                                <MudText Style="font-weight: 500;">@Localizer["SkillFirebird"]</MudText>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </div>
    </MudItem>

    <!-- Experiência -->
    <MudItem xs="12">
        <div class="animate-in" style="animation-delay: 0.3s;">
            <MudText Typo="Typo.h5" Style="font-weight: 700;" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Work" Color="Color.Primary" Class="mr-2" />
                @Localizer["ExperienceTitle"]
            </MudText>
            <MudTimeline TimelinePosition="TimelinePosition.Start" TimelineAlign="TimelineAlign.Start">
                <!-- NTT DATA -->
                <MudTimelineItem Color="Color.Primary" Size="Size.Large">
                    <MudPaper Class="pa-5 hover-card" Elevation="3" Style="border-radius: 12px;">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.h6" Style="font-weight: 700;">@Localizer["ExpNTTTitle"]</MudText>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
                                <MudText Typo="Typo.subtitle1" Color="Color.Primary" Style="font-weight: 600;">@Localizer["ExpNTTCompany"]</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">|</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Style="font-weight: 500;">@Localizer["ExpNTTPeriod"]</MudText>
                                <MudChip T="string" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" Style="font-weight: 600; border-radius: 4px;">@Localizer["Current"]</MudChip>
                            </MudStack>
                            <MudDivider Class="my-2" />
                            <div class="mt-1">
                                <MudText Typo="Typo.body2" Class="mb-2" Style="line-height: 1.6;">@Localizer["ExpNTTDesc1"]</MudText>
                                <MudText Typo="Typo.body2" Class="mb-2" Style="line-height: 1.6;">@Localizer["ExpNTTDesc2"]</MudText>
                                <MudText Typo="Typo.body2" Class="mb-2" Style="line-height: 1.6;">@Localizer["ExpNTTDesc3"]</MudText>
                                <MudText Typo="Typo.body2" Class="mb-2" Style="line-height: 1.6;">@Localizer["ExpNTTDesc4"]</MudText>
                            </div>
                        </MudStack>
                    </MudPaper>
                </MudTimelineItem>

                <!-- CRP Tecnologia -->
                <MudTimelineItem Color="Color.Secondary" Size="Size.Large">
                    <MudPaper Class="pa-5 hover-card" Elevation="3" Style="border-radius: 12px;">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.h6" Style="font-weight: 700;">@Localizer["ExpCRPTitle"]</MudText>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
                                <MudText Typo="Typo.subtitle1" Color="Color.Secondary" Style="font-weight: 600;">@Localizer["ExpCRPCompany"]</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">|</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Style="font-weight: 500;">@Localizer["ExpCRPPeriod"]</MudText>
                            </MudStack>
                            <MudDivider Class="my-2" />
                            <div class="mt-1">
                                <MudText Typo="Typo.body2" Style="line-height: 1.6;">@Localizer["ExpCRPDesc1"]</MudText>
                            </div>
                        </MudStack>
                    </MudPaper>
                </MudTimelineItem>

                <!-- Sge Automação -->
                <MudTimelineItem Color="Color.Info" Size="Size.Large">
                    <MudPaper Class="pa-5 hover-card" Elevation="3" Style="border-radius: 12px;">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.h6" Style="font-weight: 700;">@Localizer["ExpSGETitle"]</MudText>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
                                <MudText Typo="Typo.subtitle1" Color="Color.Info" Style="font-weight: 600;">@Localizer["ExpSGECompany"]</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">|</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Style="font-weight: 500;">@Localizer["ExpSGEPeriod"]</MudText>
                            </MudStack>
                            <MudDivider Class="my-2" />
                            <div class="mt-1">
                                <MudText Typo="Typo.body2" Class="mb-2" Style="line-height: 1.6;">@Localizer["ExpSGEDesc1"]</MudText>
                                <MudText Typo="Typo.body2" Class="mb-2" Style="line-height: 1.6;">@Localizer["ExpSGEDesc2"]</MudText>
                                <MudText Typo="Typo.body2" Class="mb-2" Style="line-height: 1.6;">@Localizer["ExpSGEDesc3"]</MudText>
                            </div>
                        </MudStack>
                    </MudPaper>
                </MudTimelineItem>
            </MudTimeline>
        </div>
    </MudItem>

    <!-- Formação e Certificações -->
    <MudItem xs="12">
        <div class="animate-in" style="animation-delay: 0.4s;">
            <MudGrid Spacing="3">
                <!-- Acadêmica -->
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-6 hover-card" Elevation="3" Style="border-radius: 12px; height: 100%;">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
                            <MudIcon Icon="@Icons.Material.Filled.School" Color="Color.Primary" Size="Size.Medium" />
                            <MudText Typo="Typo.h5" Style="font-weight: 700;">@Localizer["EducationTitle"]</MudText>
                        </MudStack>
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.h6" Style="font-weight: 600;">@Localizer["EduDegree"]</MudText>
                            <MudText Typo="Typo.subtitle1" Color="Color.Primary" Style="font-weight: 600;">
                                @Localizer["EduInstitution"]
                            </MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Style="font-weight: 500;">
                                @Localizer["EduPeriod"]
                            </MudText>
                        </MudStack>
                    </MudPaper>
                </MudItem>
                <!-- Certificações -->
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-6 hover-card" Elevation="3" Style="border-radius: 12px; height: 100%;">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
                            <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Color="Color.Primary" Size="Size.Medium" />
                            <MudText Typo="Typo.h5" Style="font-weight: 700;">@Localizer["CertificationsTitle"]</MudText>
                        </MudStack>
                        <MudStack Spacing="3">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                <i class="devicon-azure-plain colored" style="font-size: 2rem;"></i>
                                <MudStack Spacing="0">
                                    <MudText Style="font-weight: 600;">@Localizer["CertAzureName"]</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Microsoft</MudText>
                                </MudStack>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                <i class="devicon-github-original" style="font-size: 2rem;"></i>
                                <MudStack Spacing="0">
                                    <MudText Style="font-weight: 600;">@Localizer["CertCopilotName"]</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">GitHub</MudText>
                                </MudStack>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </div>
    </MudItem>

    <!-- Contato Fim -->
    <MudItem xs="12">
        <div class="animate-in" style="animation-delay: 0.5s;">
            <MudPaper Class="pa-6 text-center" Elevation="3" Style="border-radius: 12px; background: var(--mud-palette-background-grey);">
                <MudText Typo="Typo.h5" Style="font-weight: 700;" Class="mb-3">
                    @Localizer["ContactTitle"]
                </MudText>
                <MudText Typo="Typo.body1" Class="mb-4">
                    @Localizer["ContactText"]
                    <MudLink Href='@($"{Localizer["MailtoPrefix"]}{Localizer["EmailAddress"]}")' Style="font-weight: 600;">
                        @Localizer["EmailAddress"]
                    </MudLink>
                </MudText>
                <MudStack Row="true" Spacing="3" Justify="Justify.Center">
                    <MudButton Href='@Localizer["LinkedInUrl"]'
                               StartIcon="@Icons.Custom.Brands.LinkedIn"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               Target="_blank"
                               Size="Size.Large"
                               Style="border-radius: 8px;">
                        @Localizer["LinkedIn"]
                    </MudButton>
                    <MudButton Href='@Localizer["GitHubUrl"]'
                               StartIcon="@Icons.Custom.Brands.GitHub"
                               Variant="Variant.Filled"
                               Color="Color.Dark"
                               Target="_blank"
                               Size="Size.Large"
                               Style="border-radius: 8px;">
                        @Localizer["GitHub"]
                    </MudButton>
                </MudStack>
            </MudPaper>
        </div>
    </MudItem>
</MudGrid>

@code {
    protected override void OnInitialized()
    {
        ThemeService.OnThemeChanged += StateHasChanged;
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= StateHasChanged;
    }
}
